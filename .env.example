APP_NAME="ChubbyGenius AI"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=chubbygenius
DB_USERNAME=chubby
DB_PASSWORD=secret

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PORT=6379

# === AI PROVIDER (pilih salah satu) ===
AI_PROVIDER=gemini        # atau: openai

OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=AIzaxxxx
GEMINI_MODEL=gemini-1.5-flash

# === QUIZ SETTINGS ===
QUIZ_QUESTIONS_PER_SESSION=10
QUIZ_TIME_PER_QUESTION=30
QUIZ_STREAK_THRESHOLD=3

VITE_APP_NAME="${APP_NAME}"
